# Supabase — grab these from the Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Postgres — Supabase dashboard → Project Settings → Database → Connection string
# DATABASE_URL is the pooled (pgBouncer, port 6543) connection Prisma clients use at runtime
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL is the direct connection (port 5432) Prisma uses for migrations
DIRECT_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
